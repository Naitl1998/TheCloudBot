# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=ВСТАВЬ_ТОКЕН_ОТ_BOTFATHER

# Твой Telegram user ID (администратор)
ADMIN_CHAT_ID=ВСТАВЬ_СВОЙ_ID

# Whitelist сотрудников: Telegram ID через запятую
STAFF_IDS=

# ─── Telegram Mini App ───────────────────────────────────────────────────────
# На Render: определяется автоматически из RENDER_EXTERNAL_URL
# Локально: устанавливается через cloudflared/ngrok
WEBAPP_URL=
WEBAPP_PORT=8080

# ─── Туннель (только для локальной разработки) ────────────────────────────────
# ngrok authtoken — https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
# ngrok static domain — https://dashboard.ngrok.com/domains
NGROK_DOMAIN=

# ─── Место ────────────────────────────────────────────────────────────────────
VENUE_ADDRESS=Твой адрес
VENUE_PHONE=+84 XX XXX XXXX

# Telegram file_id логотипа (записывается в лог при первом запуске)
LOGO_URL=

# ─── Poster POS (опционально) ────────────────────────────────────────────────
POSTER_TOKEN=
POSTER_ACCOUNT=
